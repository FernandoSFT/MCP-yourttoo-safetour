# Configuración del Servidor Yourttoo MCP
# Copiar este archivo a .env y completar con valores reales

# Google Cloud Run PORT (Cloud Run lo asigna automáticamente)
PORT=8080

# API Yourttoo
YOURTTOO_API_URL=https://www.yourttoo.com
YOURTTOO_AGENCY_CODE=tu_codigo_de_agencia
YOURTTOO_ACCESS_TOKEN=tu_token_de_acceso
YOURTTOO_EMAIL=email_de_produccion@tu-agencia.es
YOURTTOO_PASSWORD=password_de_produccion

# Configuración de Testing (opcional)
YOURTTOO_API_URL_TESTING=https://apitest.yourttoo.com/
